create table riwi_supplier(
	id_supplier serial primary key,
	supplier_name varchar(150) not null,
	supplier_city varchar (100) not null
);

create table riwi_warehouse (
	id_warehouse serial primary key,
	warehouse_name varchar(100)not null,
	warehouse_city varchar(100) not null
);

create table riwi_product (
	id_product serial primary key,
	product_name varchar(150) not null,
	unit_price float not null,
	id_category int not null
);


create table riwi_inventory (
	id_inventory serial primary key,
	inventory_name varchar(150) not null,
	id_warehouse int not null,
	id_product int not null,
	product_quantity int,
	id_transaction int not null
);


create table riwi_transaction (
	id_transaction serial primary key,
	movement_date date not null,
	product_id int not null,
	quantity int not null,
	transaction_price float not null,
	movement_type varchar(30)not null,
	warehouse_id int not null
);

create table riwi_product_supplier (
	product_id int not null,
	supplier_id int not null
);


alter table riwi_product_supplier 
add constraint fk_product_supplier
foreign key (product_id)
references riwi_product (id_product);

alter table riwi_product_supplier 
add constraint fk_supplier_product
foreign key (supplier_id)
references riwi_supplier (id_supplier)

alter table riwi_inventory 
add constraint fk_inventory_warehouse
foreign key (id_warehouse)
references riwi_warehouse (id_warehouse);

alter table riwi_inventory 
add constraint fk_inventory_product
foreign key (id_product)
references riwi_product(id_product);

alter table riwi_inventory 
add constraint fk_inventory_transaction
foreign key (id_transaction)
references riwi_transaction(id_transaction);

alter table riwi_transaction 
add constraint fk_transaction_product
foreign key (product_id)
references riwi_product(id_product);

alter table riwi_transaction 
add constraint fk_transaction_warehouse
foreign key (warehouse_id)
references riwi_warehouse(id_warehouse);

